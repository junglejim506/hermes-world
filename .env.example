# Copy to .env and fill in values (all optional)

# Override Hermes home directory (default: ~/.hermes)
# HERMES_HOME=/home/youruser/.hermes

# Simulation settings (can also be passed as CLI args to orchestrator.py)
# ROUND_INTERVAL_MINUTES=5
# MAX_AGENTS=8

# Telegram is handled automatically via the Hermes gateway.
# No bot token needed here — just make sure the gateway is running:
#   hermes gateway start
