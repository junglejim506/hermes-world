# Hermes World — Environment Configuration
# Copy this file to .env and fill in your values.

# Telegram channel ID for round summaries (optional)
# Find yours: message @userinfobot on Telegram, or use your numeric user ID
# If not set, uses whatever Hermes gateway has configured
TELEGRAM_HOME_CHANNEL=your_telegram_id_here

# Simulation settings (optional, can also pass as CLI args)
# ROUND_INTERVAL_MINUTES=5
# MAX_AGENTS=8
# AGENT_DELAY_SECONDS=3

# Override Hermes home directory (default: ~/.hermes)
# HERMES_HOME=/home/youruser/.hermes
